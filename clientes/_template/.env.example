# .env do cliente — NAO commitar (.gitignore protege)
# Copie pra .env na mesma pasta e preencha.

# ─── V4mos / V4mkt ────────────────────────────────────
# Credenciais da API V4mos. Onde pegar:
#   1. Entre em https://app.v4mkt.com com sua conta V4
#   2. Selecione o workspace do cliente
#   3. Settings > API / Integracoes > gerar client credentials
#   (se nao encontrar, fale com matheus.netto@v4company.com)
#
# V4MOS_CLIENT_ID e V4MOS_CLIENT_SECRET sao suas (V4er), podem ser reusadas
# entre clientes. WORKSPACE_ID muda por cliente — e o identificador do
# workspace daquele cliente no V4mkt.

V4MOS_CLIENT_ID=
V4MOS_CLIENT_SECRET=
V4MOS_WORKSPACE_ID=

# ─── NotebookLM (opcional) ────────────────────────────
# Link pro notebook do cliente se tiver um configurado
NOTEBOOKLM_URL=

# ─── Outras integracoes (opcional) ────────────────────
# Adicione aqui credenciais especificas do cliente conforme for usando
